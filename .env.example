# app configs
NODE_ENV=development
PORT=3000

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-in-production
JWT_REFRESH_EXPIRATION=7d
JWT_ONBOARDING_SECRET=your-super-secret-oauth-onboarding-jwt-key-change-in-production
JWT_ONBOARDING_EXPIRATION=10m

# Database
POSTGRES_MASTER_URL=postgresql://postgres:postgres@localhost:5432/ttreat
POSTGRES_SLAVE_URLS=postgresql://postgres:postgres@localhost:5432/ttreat
POSTGRES_SSL=false
SCHEMA_SYNC=true
QUERY_LOGGING=true

# SMTP (using Mailhog for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_FROM_NAME=TTreat Dev
SMTP_FROM_ADDRESS=noreply@ttreat.local
APP_URL=http://localhost:3000
