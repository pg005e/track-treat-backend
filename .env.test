# app configs
NODE_ENV=test
PORT=3001

# JWT
JWT_ACCESS_SECRET=test-access-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=test-refresh-secret
JWT_REFRESH_EXPIRATION=7d
JWT_ONBOARDING_SECRET=test-onboarding-secret
JWT_ONBOARDING_EXPIRATION=10m

# Database (separate test instance on port 5433)
POSTGRES_MASTER_URL=postgresql://postgres:postgres@localhost:5433/ttreat_test
POSTGRES_SLAVE_URLS=postgresql://postgres:postgres@localhost:5433/ttreat_test
POSTGRES_SSL=false
SCHEMA_SYNC=true
QUERY_LOGGING=false

# SMTP (mocked in tests, values just need to pass config validation)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=test
SMTP_PASSWORD=test
SMTP_FROM_NAME=TTreat Test
SMTP_FROM_ADDRESS=noreply@ttreat.test
APP_URL=http://localhost:3001
